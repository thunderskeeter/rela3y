# Runtime
NODE_ENV=development
PORT=3001
DEV_MODE=false
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/relay_dashboard
PG_POOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=5000
APP_PUBLIC_BASE_URL=http://127.0.0.1:3001

# Security
AUTH_SECRET=replace-with-long-random-secret
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
CORS_ORIGINS=http://localhost:3001

# Optional dev bootstrap (development only)
ALLOW_DEFAULT_SUPERADMIN=false
DEV_DEFAULT_SUPERADMIN_EMAIL=
DEV_DEFAULT_SUPERADMIN_PASSWORD=

# Webhook auth
WEBHOOK_AUTH_TOKEN=
WEBHOOK_DEV_SECRET=

# Calendar OAuth
CAL_OAUTH_REDIRECT_BASE=http://127.0.0.1:3001
WEBHOOK_PUBLIC_BASE=
GOOGLE_CAL_CLIENT_ID=
GOOGLE_CAL_CLIENT_SECRET=
MICROSOFT_CAL_CLIENT_ID=
MICROSOFT_CAL_CLIENT_SECRET=

# AI providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Email campaigns (provider delivery)
# EMAIL_PROVIDER: resend | sendgrid
EMAIL_PROVIDER=
# Verified sender mailbox, example: "Relay <noreply@yourdomain.com>"
EMAIL_FROM=
RESEND_API_KEY=
SENDGRID_API_KEY=
# Optional safety mode: logs campaign as delivered without external API calls
EMAIL_DRY_RUN=false

# Snapshot migration flags
ENABLE_PARITY_CHECKS=true
USE_DB_CONTACTS=true
USE_DB_OPPORTUNITIES=false
USE_DB_ACTIONS=false
USE_DB_CONVERSATIONS=false
USE_DB_MESSAGES=false
USE_DB_SCHEDULER=false
